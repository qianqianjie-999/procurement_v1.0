# 密钥配置
SECRET_KEY=your-secret-key-here-please-change-in-production

# 数据库配置 (MariaDB)
DATABASE_URL=mariadb+pymysql://root:password@localhost/procurement

# 测试数据库配置
TEST_DATABASE_URL=mariadb+pymysql://root:password@localhost/procurement_test

# Flask 配置
FLASK_CONFIG=development
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000

# 邮件配置（可选）
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your-email@example.com
# MAIL_PASSWORD=your-email-password
